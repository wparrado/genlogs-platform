# Example environment variables for GenLogs backend
# Copy this file to .env and fill the values before running locally.

GENLOGS_ENV=development
GENLOGS_MAPS_PROVIDER=mock
GENLOGS_GOOGLE_API_KEY=your-google-api-key-here
GENLOGS_PREFER_MOCK_FOR_MOCK_IDS=false
GENLOGS_REQUEST_TIMEOUT_SECONDS=10
GENLOGS_RATE_LIMIT=100/minute
GENLOGS_DATABASE_URL=postgresql://user:password@localhost:5432/genlogs
GENLOGS_CACHE_CITIES_TTL_SECONDS=3600
GENLOGS_CACHE_SEARCH_TTL_SECONDS=900
GENLOGS_CACHE_MAX_SIZE=256
GENLOGS_GOOGLE_ROUTE_VEHICLE=truck
